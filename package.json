{
  "name": "txma-infra",
  "repository": {
    "type": "git",
    "url": "https://github.com/govuk-one-login/txma-infra"
  },
  "author": "GDS",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "infrastructure/dev-tools",
    "infrastructure/audit-test-tools"
  ],
  "scripts": {
    "lint": "prettier . --check || exit 1 ; eslint . --max-warnings=0",
    "lint:fix": "prettier . --write ; eslint . --fix",
    "validate:templates": "bash ./scripts/validate-templates.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-sso-oidc": "^3.1060.0",
    "@aws-sdk/client-sts": "^3.1060.0",
    "@aws-sdk/credential-provider-node": "^3.972.25"
  },
  "resolutions": {
    "micromatch": "4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smithy/core": "3.24.5",
    "@smithy/smithy-client": "4.13.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "10.1.8",
    "@vitest/eslint-plugin": "1.6.18",
    "vitest-when": "^0.10.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "lint-staged": {
    "*": "prettier --write",
    "*.{js,ts}": "eslint --fix"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.7.3"
  }
}
